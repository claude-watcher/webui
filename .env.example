# Bind address. Defaults to 127.0.0.1 (loopback). Binding a non-loopback host
# (e.g. 0.0.0.0) with no APP_AUTH_TOKEN is refused at startup unless
# APP_ALLOW_INSECURE_BIND=true — session data is served unauthenticated.
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_JSON_LOGS=
# Shared secret. Empty → API is open. Set → required on /api/sessions.
# Sent as X-API-Key or Authorization: Bearer (preferred), or ?key= (convenience;
# query strings can leak via proxy/access logs & browser history — avoid in prod).
APP_AUTH_TOKEN=
# Opt in to a non-loopback bind WITHOUT auth (e.g. a container behind -p on a
# trusted network). Leave empty unless you mean it.
APP_ALLOW_INSECURE_BIND=
# Dev only: auto-reload server on edits + browser livereload on restart.
APP_RELOAD=
